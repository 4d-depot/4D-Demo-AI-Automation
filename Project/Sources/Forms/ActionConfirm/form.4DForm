          "top": 38,
          "width": 660,
          "height": 18,
          "class": "textMuted"
        },
        "listbox_lines": {
          "type": "listbox",
          "left": 20,
          "top": 80,
          "width": 660,
          "height": 260,
          "listboxType": "collection",
          "dataSource": "Form.lines",
          "class": "lbStandard",
          "movableRows": false,
          "sortable": false,
          "selectionMode": "none",
          "events": [],
          "columns": [
            {
              "header": {
                "text": "Delta",
                "class": "lbHeaderCell"
              },
              "name": "col_delta",
              "width": 50,
              "dataSource": "This.deltaIcon",
              "class": "lbCell"
            },
            {
              "header": {
                "text": "Service",
                "class": "lbHeaderCell"
              },
              "name": "col_label",
              "width": 210,
              "dataSource": "This.label",
              "class": "lbCell"
            },
            {
              "header": {
                "text": "Catégorie",
                "class": "lbHeaderCell"
              },
              "name": "col_category",
              "width": 120,
              "dataSource": "This.category",
              "class": "lbCell"
            },
            {
              "header": {
                "text": "Qté",
                "class": "lbHeaderCell"
              },
              "name": "col_qty",
              "width": 50,
              "dataSource": "This.quantity",
              "class": "lbCellRight",
              "enterable": false
            },
            {
              "header": {
                "text": "Prix unit.",
                "class": "lbHeaderCell"
              },
              "name": "col_price",
              "width": 100,
              "dataSource": "This.unitPriceDisplay",
              "class": "lbCellRight"
            },
            {
              "header": {
                "text": "Total",
                "class": "lbHeaderCell"
              },
              "name": "col_total",
              "width": 100,
              "dataSource": "This.lineTotalDisplay",
              "class": "lbCellRight"
            }
          ]
        },
        "rect_footer": {
          "type": "rectangle",
          "left": 0,
          "top": 356,
          "width": 700,
          "height": 104,
          "class": "bgCard"
        },
        "text_impact_label": {
