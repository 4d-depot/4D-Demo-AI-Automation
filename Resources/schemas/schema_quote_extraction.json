{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eventpulse.4d/schemas/quote_extraction",
  "title": "Quote Extraction",
  "description": "Validation de l'extraction IA d'un email de demande de devis.",
  "type": "object",
  "required": ["eventType", "missingFields"],
  "properties": {
    "eventType": {
      "type": "string",
      "description": "Type d'événement détecté (séminaire, gala, lancement produit, etc.)"
    },
    "eventDate": {
      "type": "string",
      "format": "date",
      "description": "Date de l'événement détectée – format ISO 8601 YYYY-MM-DD."
    },
    "eventDateRaw": {
      "type": "string",
      "description": "Texte original de la date telle qu'exprimée dans l'email."
    },
    "guestCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100000
    },
    "guestCountApproximate": {
      "type": "boolean",
      "description": "True si le nombre d'invités est une fourchette ou approximation."
    },
    "venueHint": {
      "type": "string",
      "description": "Indication de lieu mentionnée dans l'email."
    },
    "venueCity": {
      "type": "string"
    },
    "venueCountry": {
      "type": "string"
    },
    "budgetIndicated": {
      "type": "number",
      "minimum": 0
    },
    "budgetCurrency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "durationDays": {
      "type": "integer",
      "minimum": 1
    },
    "requestedServices": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Services demandés explicitement (liste de libellés détectés)."
    },
    "dietaryRestrictions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Restrictions alimentaires mentionnées."
    },
    "specialRequirements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Exigences spéciales (NDA, accès handicapé, etc.)"
    },
    "missingFields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "importance"],
        "properties": {
          "field": {
            "type": "string",
            "enum": ["eventDate", "guestCount", "venueCity", "eventType", "budget", "duration", "catering", "av"]
          },
          "importance": {
            "type": "string",
            "enum": ["required", "recommended", "optional"]
          },
          "questionToAsk": {
            "type": "string",
            "description": "Question suggérée à poser au client pour obtenir cette information."
          }
        }
      }
    },
    "suggestedReplyTone": {
      "type": "string",
      "enum": ["formal", "friendly", "multilingual"],
      "description": "Ton suggéré pour la réponse en fonction du style de l'email."
    },
    "detectedLanguage": {
      "type": "string",
      "description": "Langue détectée dans l'email (code ISO 639-1 ou nom complet)."
    },
    "clientSentiment": {
      "type": "string",
      "enum": ["urgent", "interested", "casual", "vip"],
      "description": "Signal d'intention du client."
    }
  },
  "if": {
    "properties": { "budgetIndicated": { "type": "number" } },
    "required": ["budgetIndicated"]
  },
  "then": {
    "required": ["budgetCurrency"]
  },
  "unevaluatedProperties": false
}
