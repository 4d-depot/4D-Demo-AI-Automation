{
  "type": "object",
  "required": ["extraction", "actions"],
  "additionalProperties": false,
  "properties": {
    "extraction": {
      "type": "object",
      "required": ["eventType", "eventDate", "eventDateRaw", "guestCount", "guestCountApproximate", "venueHint", "venueCity", "venueCountry", "budgetIndicated", "budgetCurrency", "durationDays", "requestedServices", "dietaryRestrictions", "specialRequirements", "missingFields", "suggestedReplyTone", "detectedLanguage", "clientSentiment"],
      "additionalProperties": false,
      "properties": {
        "eventType": {
          "type": "string",
          "description": "Type d'événement détecté (séminaire, gala, lancement produit, etc.)"
        },
        "eventDate": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "description": "Date de l'événement – format ISO 8601 YYYY-MM-DD, ou null si non détectée."
        },
        "eventDateRaw": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "description": "Texte original de la date telle qu'exprimée dans l'email, ou null."
        },
        "guestCount": {
          "anyOf": [{ "type": "integer" }, { "type": "null" }],
          "description": "Nombre d'invités détecté, ou null."
        },
        "guestCountApproximate": {
          "type": "boolean",
          "description": "True si le nombre d'invités est une fourchette ou approximation."
        },
        "venueHint": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "description": "Indication de lieu mentionnée dans l'email, ou null."
        },
        "venueCity": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "venueCountry": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "budgetIndicated": {
          "anyOf": [{ "type": "number" }, { "type": "null" }],
          "description": "Budget indiqué, ou null."
        },
        "budgetCurrency": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "description": "Devise du budget (code 3 lettres), ou null."
        },
        "durationDays": {
          "anyOf": [{ "type": "integer" }, { "type": "null" }],
          "description": "Durée en jours, ou null."
        },
        "requestedServices": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Services demandés explicitement."
        },
        "dietaryRestrictions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Restrictions alimentaires mentionnées."
        },
        "specialRequirements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Exigences spéciales (NDA, accès handicapé, etc.)"
        },
        "missingFields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "importance", "questionToAsk"],
            "additionalProperties": false,
            "properties": {
              "field": {
                "type": "string",
                "description": "Nom du champ manquant (eventDate, guestCount, venueCity, eventType, budget, duration, catering, av)."
              },
              "importance": {
                "type": "string",
                "enum": ["required", "recommended", "optional"]
              },
              "questionToAsk": {
                "type": "string",
                "description": "Question suggérée à poser au client."
              }
            }
          }
        },
        "suggestedReplyTone": {
          "type": "string",
          "enum": ["formal", "friendly", "multilingual"],
          "description": "Ton suggéré pour la réponse."
        },
        "detectedLanguage": {
          "type": "string",
          "description": "Langue détectée (code ISO 639-1)."
        },
        "clientSentiment": {
          "type": "string",
          "enum": ["urgent", "interested", "casual", "vip"],
          "description": "Signal d'intention du client."
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actionType", "label", "description", "priority", "icon", "hiddenPrompt"],
        "additionalProperties": false,
        "properties": {
          "actionType": {
            "type": "string",
            "enum": [
              "prepare_quote",
              "draft_reply",
              "flag_missing_info",
              "weather_alert",
              "propose_contingency",
              "notify_client_weather",
              "process_modification",
              "resolve_ambiguity",
              "calculate_impact",
              "send_avenant"
            ]
          },
          "label": {
            "type": "string",
            "description": "Libellé court du bouton d'action."
          },
          "description": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "description": "Description longue affichée dans le panneau IA."
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "icon": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "description": "Emoji ou nom d'icône."
          },
          "hiddenPrompt": {
            "type": "string",
            "description": "Prompt caché décrivant précisément ce que l'action doit faire. Doit contenir le contexte métier complet : services à rechercher, quantités estimées, contraintes spécifiques. Ce prompt sera envoyé à l'IA lors de l'exécution avec un outil de recherche de services."
          }
        }
      }
    }
  }
}
